# Root .gitignore for orphanage management project

# Java / Maven
target/
*.class
*.jar
*.war
*.ear
.classpath
.project
.settings/
.idea/
*.iml

# Maven wrapper
/.mvn/

# Node
/frontend/node_modules/
node_modules/
dist/
dist-ssr/
build/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment
.env
.env.local
.env.*.local
*.local

# VS Code
.vscode/*
!.vscode/extensions.json

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.swp
*.sw?

# IDE/workspace
workspace.xml
*.suo
*.ntvs*
*.njsproj
*.sln
